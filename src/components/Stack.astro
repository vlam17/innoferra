---
// The four-layer platform, rendered top-down (L4 → L1) with an energy beam
// rising from power to tokens. Layer copy comes from the company deck.
const layers = [
  {
    id: 'L4',
    title: 'AI Token Factory & Inference Software',
    body: 'Proprietary serving platform with industry-leading time-to-first-token and throughput.',
    owner: 'Innoferra',
    accent: true,
  },
  {
    id: 'L3',
    title: 'Elite GPU Compute',
    body: 'Inference-optimized NVIDIA B300, GB300 and H200 fleets, alongside AMD MI350.',
    owner: 'Innoferra',
    accent: true,
  },
  {
    id: 'L2',
    title: 'Data Centers',
    body: 'Liquid-cooled, purpose-built data center capacity on priority, arm’s-length terms.',
    owner: 'Innomatrix · affiliate',
    accent: false,
  },
  {
    id: 'L1',
    title: 'Power',
    body: 'Shovel-ready, low-cost Texas power with priority access as Innoferra scales.',
    owner: 'Innomatrix · affiliate',
    accent: false,
  },
];
---

<section id="platform" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="max-w-3xl" data-reveal>
      <p class="text-[11px] font-semibold tracking-[0.25em] text-pulse-400 uppercase">The platform</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-mist-100 sm:text-5xl">
        Vertically integrated, from grid to token
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-mist-400">
        Innoferra operates the compute and software layers of the stack. Power and purpose-built data
        centers are supplied by affiliate Innomatrix — a structural scaling advantage that means lower
        costs and faster expansion.
      </p>
    </div>

    <div class="relative mt-14" data-reveal style="--reveal-delay: 120ms">
      <!-- Energy beam: rises from L1 (power) to L4 (tokens) -->
      <div class="absolute top-2 bottom-2 left-4 w-px overflow-hidden sm:left-6" aria-hidden="true">
        <div class="beam-fill h-full w-full bg-gradient-to-t from-ember-500 via-pulse-500 to-pulse-300"></div>
        <div class="beam-particle absolute bottom-0 left-1/2 h-10 w-[3px] -translate-x-1/2 rounded-full bg-pulse-300 blur-[1px]"></div>
        <div class="beam-particle beam-particle-2 absolute bottom-0 left-1/2 h-10 w-[3px] -translate-x-1/2 rounded-full bg-ember-400 blur-[1px]"></div>
      </div>

      <ol class="space-y-4 pl-12 sm:pl-16" role="list">
        {
          layers.map((layer, i) => (
            <li
              class:list={[
                'relative rounded-2xl border p-6 transition-colors sm:p-7',
                layer.accent
                  ? 'border-pulse-500/25 bg-void-850 hover:border-pulse-400/50'
                  : 'border-white/8 bg-void-900/70 hover:border-white/20',
              ]}
              data-reveal
              style={`--reveal-delay: ${160 + i * 90}ms`}
            >
              <span
                class:list={[
                  'absolute top-1/2 -left-12 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full border font-display text-xs font-bold sm:-left-[3.25rem]',
                  layer.accent
                    ? 'border-pulse-500/40 bg-void-900 text-pulse-300'
                    : 'border-ember-500/40 bg-void-900 text-ember-400',
                ]}
                aria-hidden="true"
              >
                {layer.id}
              </span>
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
                <h3 class="font-display text-lg font-semibold text-mist-100 sm:text-xl">{layer.title}</h3>
                <p
                  class:list={[
                    'text-[11px] font-semibold tracking-[0.18em] uppercase',
                    layer.accent ? 'text-pulse-400' : 'text-ember-400',
                  ]}
                >
                  {layer.owner}
                </p>
              </div>
              <p class="mt-2 max-w-2xl text-[15px] leading-relaxed text-mist-400">{layer.body}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <p class="mt-8 pl-12 text-sm text-mist-500 sm:pl-16" data-reveal>
      <span class="font-semibold text-ember-400">▲</span>{' '}
      Affiliate Innomatrix supplies layers L1–L2 — priority access without the capex.
    </p>
  </div>
</section>
