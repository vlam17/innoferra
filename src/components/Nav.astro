---
const links = [
  { href: '#platform', label: 'Platform' },
  { href: '#services', label: 'Services' },
  { href: '#technology', label: 'Technology' },
  { href: '#team', label: 'Team' },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-white/5 bg-void-950/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8" aria-label="Main">
    <a href="#top" class="flex items-baseline gap-2">
      <span class="font-display text-xl font-bold tracking-tight text-mist-100">
        inno<span class="text-pulse-400">ferra</span>
      </span>
      <span class="hidden text-[11px] font-medium tracking-widest text-mist-500 uppercase sm:inline">
        an Innomatrix company
      </span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {
        links.map(({ href, label }) => (
          <a href={href} class="text-sm font-medium text-mist-400 transition-colors hover:text-mist-100">
            {label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="rounded-full bg-pulse-500 px-4 py-1.5 text-sm font-semibold text-void-950 transition hover:bg-pulse-400"
      >
        Get in touch
      </a>
    </div>

    <button
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-md text-mist-100 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
      data-menu-button
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/5 bg-void-900/95 px-5 pt-2 pb-4 md:hidden" data-menu>
    {
      [...links, { href: '#contact', label: 'Get in touch' }].map(({ href, label }) => (
        <a href={href} class="block py-2.5 text-base font-medium text-mist-300 hover:text-mist-100" data-menu-link>
          {label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const button = document.querySelector('[data-menu-button]');
  const menu = document.querySelector('[data-menu]');
  button?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    button.setAttribute('aria-expanded', String(open));
  });
  document.querySelectorAll('[data-menu-link]').forEach((link) =>
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      button?.setAttribute('aria-expanded', 'false');
    }),
  );
</script>
