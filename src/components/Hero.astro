---
---

<section id="top" class="relative overflow-hidden pt-16">
  <!-- Background: radial glow + grid, parallax-shifted -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="parallax-layer absolute -top-40 left-1/2 h-[640px] w-[1100px] -translate-x-1/2 rounded-full opacity-70"
      data-speed="0.25"
      style="background: radial-gradient(closest-side, rgba(22,194,240,0.16), transparent 70%);"
    >
    </div>
    <div
      class="parallax-layer absolute inset-0 opacity-[0.35]"
      data-speed="0.12"
      style="background-image: linear-gradient(rgba(124,234,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(124,234,255,0.05) 1px, transparent 1px); background-size: 56px 56px;"
    >
    </div>
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col items-center px-5 pt-20 pb-24 text-center sm:px-8 sm:pt-28 sm:pb-32">
    <p
      class="mb-6 rounded-full border border-pulse-500/30 bg-pulse-500/10 px-4 py-1.5 text-[11px] font-semibold tracking-[0.2em] text-pulse-300 uppercase"
      data-reveal
    >
      From electricity to intelligence
    </p>

    <h1
      class="max-w-4xl font-display text-4xl leading-[1.05] font-bold tracking-tight text-mist-100 sm:text-6xl lg:text-7xl"
      data-reveal
      style="--reveal-delay: 80ms"
    >
      Powering the{' '}
      <span class="bg-gradient-to-r from-pulse-300 via-pulse-400 to-ember-400 bg-clip-text text-transparent">
        Inference Era
      </span>
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-mist-400 sm:text-xl" data-reveal style="--reveal-delay: 160ms">
      Innoferra is an AI inference cloud — elite GPU fleets and a proprietary token factory that turn
      low-cost power into high-performance intelligence.
    </p>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row" data-reveal style="--reveal-delay: 240ms">
      <a
        href="#contact"
        class="rounded-full bg-pulse-500 px-7 py-3 text-base font-semibold text-void-950 transition hover:bg-pulse-400"
      >
        Talk to Innoferra
      </a>
      <a
        href="#services"
        class="rounded-full border border-white/15 px-7 py-3 text-base font-semibold text-mist-100 transition hover:border-pulse-400/50 hover:text-pulse-300"
      >
        Explore the platform
      </a>
    </div>

    <dl class="mt-16 grid w-full max-w-3xl grid-cols-1 gap-4 sm:grid-cols-3" data-reveal style="--reveal-delay: 320ms">
      {
        [
          ['GPU Cloud', 'Dedicated bare-metal clusters'],
          ['AI Token Factory', 'Managed per-token inference'],
          ['99.9% SLA', 'Enterprise-grade reliability'],
        ].map(([term, detail]) => (
          <div class="rounded-xl border border-white/8 bg-void-900/60 px-5 py-4">
            <dt class="font-display text-base font-semibold text-mist-100">{term}</dt>
            <dd class="mt-1 text-sm text-mist-500">{detail}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
