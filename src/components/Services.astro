---
// The two contracted offerings, from the deck's "Two Ways to Engage" slide.
const specsGpu = [
  ['Hardware', 'B300 · GB300 · H200 · MI350'],
  ['Deployment', 'Single-tenant bare metal'],
  ['Reliability', '99.9% SLA'],
  ['Who it serves', 'AI clouds & enterprises'],
];

const specsTokens = [
  ['Pricing', 'Per-token'],
  ['Performance', 'Leading time-to-first-token'],
  ['Serving stack', 'Proprietary'],
  ['Who it serves', 'App developers & neoclouds'],
];

const models = ['DeepSeek', 'Qwen', 'Kimi', 'GLM', 'MiniMax', 'OpenAI'];
---

<section id="services" class="relative py-24 sm:py-32">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" aria-hidden="true"></div>

  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="max-w-3xl" data-reveal>
      <p class="text-[11px] font-semibold tracking-[0.25em] text-pulse-400 uppercase">Services</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-mist-100 sm:text-5xl">
        Two ways to engage
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-mist-400">
        Reserved bare-metal GPU clusters or fully managed per-token inference — engage Innoferra’s
        fleet the way your workload demands.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      <!-- 01 · GPU Cloud -->
      <article
        class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/8 bg-void-900/70 p-7 transition-colors hover:border-pulse-400/40 sm:p-9"
        data-reveal
      >
        <div
          class="pointer-events-none absolute -top-24 -right-24 h-56 w-56 rounded-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          style="background: radial-gradient(closest-side, rgba(22,194,240,0.14), transparent 70%);"
          aria-hidden="true"
        >
        </div>
        <p class="text-[11px] font-semibold tracking-[0.25em] text-mist-500 uppercase">01 · GPU Cloud</p>
        <h3 class="mt-3 font-display text-2xl font-bold text-mist-100 sm:text-3xl">Dedicated GPU Clusters</h3>
        <p class="mt-4 leading-relaxed text-mist-400">
          Reserved bare-metal NVIDIA and AMD clusters — single-tenant, isolated, and inference-optimized.
          Full control and data sovereignty at ultra-low total cost of ownership, without the capex.
        </p>
        <dl class="mt-7 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
          {
            specsGpu.map(([term, detail]) => (
              <div class="border-l border-pulse-500/30 pl-4">
                <dt class="text-[11px] font-semibold tracking-[0.18em] text-mist-500 uppercase">{term}</dt>
                <dd class="mt-1 text-sm font-medium text-mist-100">{detail}</dd>
              </div>
            ))
          }
        </dl>
        <p class="mt-auto pt-8 text-[11px] font-semibold tracking-[0.2em] text-pulse-400 uppercase">
          Bare metal · Reserved capacity
        </p>
      </article>

      <!-- 02 · Token Factory -->
      <article
        class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/8 bg-void-900/70 p-7 transition-colors hover:border-ember-400/40 sm:p-9"
        data-reveal
        style="--reveal-delay: 120ms"
      >
        <div
          class="pointer-events-none absolute -top-24 -right-24 h-56 w-56 rounded-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          style="background: radial-gradient(closest-side, rgba(245,158,11,0.12), transparent 70%);"
          aria-hidden="true"
        >
        </div>
        <p class="text-[11px] font-semibold tracking-[0.25em] text-mist-500 uppercase">02 · Token Factory</p>
        <h3 class="mt-3 font-display text-2xl font-bold text-mist-100 sm:text-3xl">Model-as-a-Service</h3>
        <p class="mt-4 leading-relaxed text-mist-400">
          Fully managed inference on our proprietary serving stack — per-token pricing and leading
          time-to-first-token, delivered through direct enterprise endpoints and marketplaces.
        </p>
        <dl class="mt-7 grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
          {
            specsTokens.map(([term, detail]) => (
              <div class="border-l border-ember-500/30 pl-4">
                <dt class="text-[11px] font-semibold tracking-[0.18em] text-mist-500 uppercase">{term}</dt>
                <dd class="mt-1 text-sm font-medium text-mist-100">{detail}</dd>
              </div>
            ))
          }
        </dl>
        <div class="mt-7">
          <p class="text-[11px] font-semibold tracking-[0.18em] text-mist-500 uppercase">Leading open models</p>
          <ul class="mt-3 flex flex-wrap gap-2" role="list">
            {
              models.map((m) => (
                <li class="rounded-full border border-white/10 bg-void-850 px-3 py-1 text-xs font-medium text-mist-300">
                  {m}
                </li>
              ))
            }
          </ul>
        </div>
        <p class="mt-auto pt-8 text-[11px] font-semibold tracking-[0.2em] text-ember-400 uppercase">
          Managed inference · Per token
        </p>
      </article>
    </div>
  </div>
</section>
