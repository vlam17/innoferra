---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Innoferra — Powering the Inference Era',
  description =
    'Innoferra is an AI inference cloud: elite GPU fleets and a proprietary token factory. Dedicated GPU clusters and fully managed per-token inference — from electricity to intelligence.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en" class="scheme-dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="theme-color" content="#05070f" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Innoferra" />
    <meta name="generator" content={Astro.generator} />
    <script>
      // Marker class: reveal-hiding styles only apply when JS runs,
      // so the page renders fully with JS disabled.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:bg-pulse-500 focus:px-4 focus:py-2 focus:font-semibold focus:text-void-950"
    >
      Skip to content
    </a>
    <slot />
    <script>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Scroll-triggered reveals
      const revealed = document.querySelectorAll('[data-reveal]');
      if (reduced) {
        revealed.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
        );
        revealed.forEach((el) => io.observe(el));
      }

      // Subtle hero parallax
      const layers = document.querySelectorAll<HTMLElement>('.parallax-layer');
      if (!reduced && layers.length) {
        let ticking = false;
        const update = () => {
          const y = window.scrollY;
          layers.forEach((el) => {
            const speed = Number(el.dataset.speed ?? 0.2);
            el.style.transform = `translateY(${y * speed}px)`;
          });
          ticking = false;
        };
        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(update);
            }
          },
          { passive: true },
        );
      }
    </script>
  </body>
</html>
